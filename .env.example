# App connection: low-privilege role used by Streamlit.
DATABASE_URL=postgresql://dialin_app:dialin_app@localhost:5432/dialin

# Migration/seed connection: owner/admin role. Never use this in the app.
MIGRATION_DATABASE_URL=postgresql://dialin_owner:dialin_owner@localhost:5432/dialin

# Optional role name used by migrations for grants when the role exists.
APP_DATABASE_ROLE=dialin_app
